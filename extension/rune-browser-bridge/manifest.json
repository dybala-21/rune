{
  "manifest_version": 3,
  "name": "RUNE Browser Bridge",
  "version": "1.2.0",
  "description": "RUNE AI Agent가 현재 Chrome 브라우저를 제어할 수 있도록 CDP 브릿지를 제공합니다.",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "ws://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RUNE Browser Bridge"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
