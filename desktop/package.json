{
  "name": "rune-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "RUNE desktop shell — a hardened Electron window over the RUNE web UI + daemon.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "RUNE_UI_URL=http://localhost:5173 electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "dev.rune.desktop",
    "productName": "RUNE",
    "files": [
      "main.js",
      "preload.js"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "dybala-21",
      "repo": "rune"
    }
  }
}
